namespace web

route brave_search(BraveSearchArg, BraveSearchResult, BraveSearchError)
    "Search web for LLM context using Brave Search API."

struct BraveSearchArg
    q String(min_length=1)
        "Web search query. Additional parameters include:
        
        Use quotes for exact phrase matching: \"climate change solutions\"
        Exclude terms with minus: javascript -jquery
        Site-specific searches: site:github.com rust tutorials
        File type searches: filetype:pdf machine learning"
    count UInt32 = 5
    freshness BraveFreshness?

union BraveFreshness
    pd
        "Past 24 hours"
    pw
        "Past 7 days"
    pm
        "Past 31 days"
    py
        "Past year"
    custom String
        "Custom date range. Example: 2022-04-01to2022-07-30"

struct BraveSearchResult
    grounding BraveGrounding

struct BraveGrounding
    generic List(BraveSearchHit)

struct BraveSearchHit
    url String
    title String
    snippets List(String)

union BraveSearchError
    bad_q
    limit_exceeded
        "The active account has made too many search queries."
